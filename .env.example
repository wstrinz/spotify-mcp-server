# Spotify OAuth Configuration
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# OAuth Server Configuration
REDIRECT_URL=http://localhost:8888/callback
# IMPORTANT: set a long random value in production (do NOT ship the default).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
OAUTH_ISSUER=http://localhost:8888

# Server Configuration
PORT=8888

# Durable auth storage
# Path to the JSON file holding long-lived Spotify refresh tokens. This file
# MUST live on a persistent volume so auth survives restarts/redeploys.
# On Coolify, mount a persistent volume at the directory containing this file
# (e.g. mount a volume at /app/data and leave the default below).
AUTH_STORE_PATH=./data/auth-store.json